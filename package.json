{
  "name": "workscheduler",
  "version": "1.0.0",
  "main": "index.ts",
  "author": "WorkScheduler",
  "description": "Work Scheduling App",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "electron": "powershell -ExecutionPolicy Bypass -File electron-app/start.ps1",
    "build:web": "expo export -p web"
  },
  "build": {
    "appId": "com.workscheduler.app",
    "productName": "Work Scheduler",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-app/main.js",
      "dist-web/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.png",
      "verifyUpdateCodeSignature": false
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.15.13",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.14.14",
    "@vercel/analytics": "^2.0.1",
    "expo": "~54.0.33",
    "expo-device": "~8.0.10",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.13.0",
    "i18next": "^26.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.7",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-paper": "^5.15.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.10"
  },
  "private": true
}
